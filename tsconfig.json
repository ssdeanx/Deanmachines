{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ESNext", "DOM"],
    "target": "ES2022",
    "jsx": "react", 
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "**/node_modules/*"]
}
